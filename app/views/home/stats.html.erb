<h1>Live stats <small class="muted">(auto-refresh every 2s)</small></h1>

<div class="live-panel" data-poll="/stats.json" data-renderer="live-stats">Loading…</div>

<h2>Recent runs (last 50)</h2>
<% if @recent.empty? %>
  <p class="muted">Nothing has run yet. Enqueue something from the home page.</p>
<% else %>
  <table>
    <thead>
      <tr><th>Job</th><th>Account</th><th>Payload</th><th>Ran at</th></tr>
    </thead>
    <tbody>
      <% @recent.each do |r| %>
        <tr>
          <td><code><%= r.job_class %></code></td>
          <td><%= r.account_id || "—" %></td>
          <td><code><%= r.payload.to_json %></code></td>
          <td><%= r.ran_at %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
