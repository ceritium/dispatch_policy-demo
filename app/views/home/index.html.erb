<h1>DispatchPolicy playground</h1>
<p class="muted">Every form below enqueues jobs through the gem. Tweak numbers, scroll down to watch the live panel drain the queue under the declared gates.</p>

<%= render "dispatch_form",
  title:   "EmailJob — throttle + dedupe",
  desc:    "rate: 5/minute per account, dedupe on (account, subject). Enqueue 20 to watch it drain at ~1/12s.",
  kind:    "email",
  fields:  %i[account subject count wait batch],
  accounts: @accounts %>

<%= render "dispatch_form",
  title:   "ReportJob — concurrency + fair_interleave",
  desc:    "Max 2 in-flight per account, fair_interleave mixes accounts in the admission order.",
  kind:    "report",
  fields:  %i[account count wait batch],
  accounts: @accounts %>

<%= render "dispatch_form",
  title:   "TenantWorkJob — round_robin_by + adaptive_concurrency",
  desc:    "Fair tenant fetch + a cap that shrinks when the tenant's performs are slow. Account A = 100ms, B = 400ms, C = 900ms; watch A's cap grow toward 20 while C's shrinks toward 1.",
  kind:    "tenant_work",
  fields:  %i[account task count wait batch],
  accounts: @accounts %>

<%= render "dispatch_form",
  title:   "WebhookDeliveryJob — throttle + fair_time_share",
  desc:    "Throttle 60/min/account is the ceiling. fair_time_share rebalances admission ordering by recent compute time. Each account has a fixed perform duration (fast=50ms, medium=200ms, slow=1s). Enqueue from one account: it runs at the throttle ceiling. Add a second account: both share total compute time — the slow one gets fewer admissions, the fast one gets more.",
  kind:    "webhook",
  fields:  %i[account count wait batch],
  accounts: @webhook_accounts %>

<%= render "dispatch_form",
  title:   "MaintenanceJob — global_cap",
  desc:    "At most 3 running at a time across the whole policy. No per-tenant partition.",
  kind:    "maintenance",
  fields:  %i[task count wait batch],
  accounts: @accounts %>

<%= form_with url: storms_path, method: :post, local: true, html: { class: "dispatch" } do |f| %>
  <h3>Storm — stress test with many accounts</h3>
  <p class="desc">
    For <em>duration</em> seconds, enqueue TenantWorkJob for many distinct
    <code>acc_1</code>..<code>acc_N</code> accounts with weight = account number
    (so higher-numbered accounts are proportionally more likely).
    Exercises the admin UI, round-robin fairness, and the adaptive gate with
    hundreds of partitions and a skewed distribution.
  </p>
  <div class="fields">
    <label>
      num_accounts
      <%= f.number_field :num_accounts, value: 100, min: 1, max: 2000 %>
    </label>
    <label>
      duration (s)
      <%= f.number_field :duration_seconds, value: 60, min: 1, max: 600 %>
    </label>
    <label>
      batch_size
      <%= f.number_field :batch_size, value: 20, min: 1, max: 200 %>
    </label>
    <button type="submit">Start storm</button>
  </div>
<% end %>

<div class="live-panel" data-poll="/stats.json" data-renderer="live-stats">Loading…</div>
